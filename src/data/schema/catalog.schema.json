{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unihub.local/schema/catalog.schema.json",
  "title": "UniHub catalog",
  "type": "object",
  "required": ["academicYears"],
  "additionalProperties": false,
  "properties": {
    "academicYears": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "order", "studyYears"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "order": { "type": "number" },
          "studyYears": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "order", "semesters"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "order": { "type": "number" },
                "semesters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "order"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string", "minLength": 1 },
                      "order": { "type": "number" },
                      "courses": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["id", "title"],
                          "additionalProperties": false,
                          "properties": {
                            "id": { "type": "string", "minLength": 1 },
                            "title": { "type": "string", "minLength": 1 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
