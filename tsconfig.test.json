{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist-test",
    "rootDir": "."
  },
  "include": ["src/domain/**/*.ts", "src/lib/**/*.ts", "public/data/**/*.json", "tests/**/*.ts"]
}
